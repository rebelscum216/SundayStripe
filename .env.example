# Example environment variables for local development.
# Copy this to .env and fill in real values.
# Do NOT commit real secrets to git.

# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hub

# Redis
REDIS_URL=redis://localhost:6379

# Shopify App (from Partners dashboard)
SHOPIFY_SHOP=your-shopify-store.myshopify.com
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_SCOPES=read_products,write_products,read_inventory,write_inventory
SHOPIFY_APP_URL=http://localhost:3001
SHOPIFY_API_VERSION=2025-10
FRONTEND_URL=http://localhost:3000

# Encryption key for stored tokens (32-byte hex)
TOKEN_ENCRYPTION_KEY=

# App
NODE_ENV=development

GSC_CREDENTIALS=/path/to/client_secret.json
GSC_TOKEN=/path/to/token.json
GSC_SITE=sc-domain:yourdomain.com

AMAZON_CLIENT_ID=your-amazon-client-id
AMAZON_CLIENT_SECRET=your-amazon-client-secret
AMAZON_REFRESH_TOKEN=your-amazon-refresh-token
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
AMAZON_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

AMAZON_CLIENT_ID_PROD=your-amazon-prod-client-id
AMAZON_SECRET_PROD=your-amazon-prod-client-secret
AMAZON_REFRESH_TOKEN_PROD=your-amazon-prod-refresh-token

GOOGLE_MERCHANT_CREDENTIALS=/path/to/google-merchant-credentials.json
GOOGLE_MERCHANT_ID=your-google-merchant-id
GOOGLE_MERCHANT_DEVELOPER_EMAIL=your-email@example.com

OPENAI_API_KEY=your-openai-api-key
