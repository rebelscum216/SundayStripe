{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "./node_modules/.bin/tsc -p packages/db/tsconfig.json && pnpm --filter @sunday-stripe/api build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @sunday-stripe/db migrate && node apps/api/dist/main.js",
    "healthcheckPath": "/api/status",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
