{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm --filter @sunday-stripe/db build && pnpm --filter @sunday-stripe/api build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @sunday-stripe/db migrate && node apps/api/dist/main.js",
    "healthcheckPath": "/api/status",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
