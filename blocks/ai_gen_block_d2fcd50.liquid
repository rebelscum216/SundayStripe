{% doc %}
  @prompt
    3 images next to each other , A title field above the images and a link to product pages under each image 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-three-images-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-three-images-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.heading_alignment }};
  }

  .ai-three-images-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-three-images-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.link_spacing }}px;
  }

  .ai-three-images-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-three-images-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: {{ block.settings.aspect_ratio }};
  }

  .ai-three-images-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-three-images-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-three-images-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-three-images-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.link_bg_color }};
    color: {{ block.settings.link_text_color }};
    text-decoration: none;
    text-align: center;
    border-radius: {{ block.settings.link_border_radius }}px;
    transition: background-color 0.3s ease;
  }

  .ai-three-images-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.link_hover_bg_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-three-images-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap | times: 0.75 }}px;
    }

    .ai-three-images-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<three-images-{{ ai_gen_id }} class="ai-three-images-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-three-images-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-three-images-container-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign product_key = 'product_' | append: i
        assign image = block.settings[image_key]
        assign product = block.settings[product_key]
      %}
      <div class="ai-three-images-item-{{ ai_gen_id }}">
        <div class="ai-three-images-image-wrapper-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-three-images-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-three-images-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-three-images-empty-state-{{ ai_gen_id }}">
                Add image {{ i }}
              </div>
            </div>
          {% endif %}
        </div>

        {% if product != blank %}
          <a href="{{ product.url }}" class="ai-three-images-link-{{ ai_gen_id }}">
            {{ block.settings.link_text }}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</three-images-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Three images",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#007395"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Spacing below heading",
      "default": 24
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product 3"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "1 / 1",
          "label": "Square"
        },
        {
          "value": "4 / 3",
          "label": "Landscape"
        },
        {
          "value": "3 / 4",
          "label": "Portrait"
        },
        {
          "value": "16 / 9",
          "label": "Wide"
        }
      ],
      "default": "1 / 1"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Gap between images",
      "default": 8
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Product links"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "View product"
    },
    {
      "type": "range",
      "id": "link_spacing",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Spacing above link",
      "default": 12
    },
    {
      "type": "color",
      "id": "link_bg_color",
      "label": "Link background",
      "default": "#cf3333"
    },
    {
      "type": "color",
      "id": "link_text_color",
      "label": "Link text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_hover_bg_color",
      "label": "Link hover background",
      "default": "#007395"
    },
    {
      "type": "range",
      "id": "link_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Link border radius",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Three images"
    }
  ]
}
{% endschema %}
